<%- include('partials/head') %>
<div class="card form-card">
  <div class="progress"><div class="progress-bar" style="width:<%= Math.round(step/steps*100) %>%"></div></div>
  <p class="muted">Step <%= step %> of <%= steps %></p>
  <form method="post" action="/questionnaire">
    <input type="hidden" name="step" value="<%= step %>">

    <% if (step === 1) { %>
      <h2>About you</h2>
      <label>Your first name<input name="founder_name" value="<%= q.founder_name || '' %>" required></label>
      <label>Age range
        <select name="age_range"><% ['18-24','25-34','35-44','45-54','55+'].forEach(o=>{ %><option <%= q.age_range===o?'selected':'' %>><%= o %></option><% }) %></select>
      </label>
      <label>Current work status
        <select name="work_status"><% ['Employed full-time','Employed part-time','Freelancing','Between jobs','Student','Parent / caregiver'].forEach(o=>{ %><option <%= q.work_status===o?'selected':'' %>><%= o %></option><% }) %></select>
      </label>
      <label>Industry / field you know best<input name="industry_field" value="<%= q.industry_field || '' %>" placeholder="e.g. healthcare, retail, software"></label>
      <label>Where are you based?<input name="location" value="<%= q.location || '' %>" placeholder="City, country"></label>
      <label>Credentials or qualifications (optional)<input name="credentials" value="<%= q.credentials || '' %>" placeholder="degrees, licenses, certifications"></label>

    <% } else if (step === 2) { %>
      <h2>Skills &amp; passions</h2>
      <label>Your top skills (comma-separated)<input name="skills" value="<%= (q.skills||[]).join(', ') %>" placeholder="writing, sales, design…" required></label>
      <label>Hobbies (comma-separated)<input name="hobbies" value="<%= (q.hobbies||[]).join(', ') %>"></label>
      <label>Your superpower — the thing you do better than most<input name="superpower" value="<%= q.superpower || '' %>"></label>
      <label>A topic you could talk about for hours<input name="passion_topic" value="<%= q.passion_topic || '' %>"></label>
      <label>What do people ask your advice on?<input name="advice_topic" value="<%= q.advice_topic || '' %>"></label>
      <label>A problem that genuinely frustrates you<textarea name="problem_pain" rows="2"><%= q.problem_pain || '' %></textarea></label>
      <fieldset><legend>What kind of work energizes you?</legend>
        <% ['Creating things','Helping people','Solving problems','Teaching','Selling & persuading','Organizing & systems'].forEach(o=>{ %>
          <label class="check"><input type="checkbox" name="energizing_work" value="<%= o %>" <%= (q.energizing_work||[]).includes(o)?'checked':'' %>> <%= o %></label>
        <% }) %>
      </fieldset>
      <label>Tech comfort level (1 = newbie, 5 = builder)
        <select name="tech_level"><% [1,2,3,4,5].forEach(o=>{ %><option <%= q.tech_level===o?'selected':'' %>><%= o %></option><% }) %></select>
      </label>

    <% } else if (step === 3) { %>
      <h2>Work style</h2>
      <label>Preferred work mode
        <select name="work_mode"><% ['Fully online','Local / in-person','Hybrid'].forEach(o=>{ %><option <%= q.work_mode===o?'selected':'' %>><%= o %></option><% }) %></select>
      </label>
      <label>Solo or with others?
        <select name="team_preference"><% ['Solo founder','Co-founder wanted','Small team eventually'].forEach(o=>{ %><option <%= q.team_preference===o?'selected':'' %>><%= o %></option><% }) %></select>
      </label>
      <label>Your stance on using AI in your business
        <select name="ai_stance"><% ['All-in on AI','Use it where helpful','Prefer minimal AI'].forEach(o=>{ %><option <%= q.ai_stance===o?'selected':'' %>><%= o %></option><% }) %></select>
      </label>
      <label>Risk tolerance
        <select name="risk_tolerance"><% ['Low — steady and safe','Medium — calculated bets','High — go big'].forEach(o=>{ %><option <%= q.risk_tolerance===o?'selected':'' %>><%= o %></option><% }) %></select>
      </label>
      <label>Hustle mode
        <select name="hustle_mode"><% ['Side hustle','Serious part-time','All-in full-time'].forEach(o=>{ %><option <%= q.hustle_mode===o?'selected':'' %>><%= o %></option><% }) %></select>
      </label>
      <label>Hours per week you can commit
        <select name="hours_per_week"><% ['<5','5-10','10-20','20-40','40+'].forEach(o=>{ %><option <%= q.hours_per_week===o?'selected':'' %>><%= o %></option><% }) %></select>
      </label>

    <% } else if (step === 4) { %>
      <h2>Goals &amp; constraints</h2>
      <label>Launch budget
        <select name="launch_budget"><% ['$0','Under $500','$500-2,000','$2,000-10,000','$10,000+'].forEach(o=>{ %><option <%= q.launch_budget===o?'selected':'' %>><%= o %></option><% }) %></select>
      </label>
      <label>Financial runway
        <select name="runway"><% ['None — need income now','1-3 months','3-6 months','6-12 months','12+ months'].forEach(o=>{ %><option <%= q.runway===o?'selected':'' %>><%= o %></option><% }) %></select>
      </label>
      <label>Year-1 income goal
        <select name="income_year1"><% ['Side income ($500+/mo)','Replace part of salary','Replace full salary','Build something big'].forEach(o=>{ %><option <%= q.income_year1===o?'selected':'' %>><%= o %></option><% }) %></select>
      </label>
      <label>Do you already have a business idea?
        <select name="has_idea" id="has_idea"><% ['no','sort of','yes'].forEach(o=>{ %><option <%= q.has_idea===o?'selected':'' %>><%= o %></option><% }) %></select>
      </label>
      <label>If yes — describe it<textarea name="idea_description" rows="2"><%= q.idea_description || '' %></textarea></label>
      <fieldset><legend>Business models you're drawn to</legend>
        <% ['Services / freelancing','Digital products','E-commerce','SaaS / software','Content & audience','Local business','Coaching / consulting'].forEach(o=>{ %>
          <label class="check"><input type="checkbox" name="biz_models" value="<%= o %>" <%= (q.biz_models||[]).includes(o)?'checked':'' %>> <%= o %></label>
        <% }) %>
      </fieldset>
      <label>Deal breakers (comma-separated)<input name="deal_breakers" value="<%= (q.deal_breakers||[]).join(', ') %>" placeholder="e.g. cold calling, inventory, video content"></label>
      <label>Describe your ideal workday<textarea name="ideal_day" rows="2"><%= q.ideal_day || '' %></textarea></label>
      <label>What would you regret never trying?<input name="regret" value="<%= q.regret || '' %>"></label>
      <label>Your biggest fear about starting<input name="biggest_fear" value="<%= q.biggest_fear || '' %>"></label>

    <% } else { %>
      <h2>Strategy &amp; experience</h2>
      <label>Would you rather pursue…
        <select name="competition_preference">
          <% ['Something niche with less competition','Something commonplace with more competition (proven demand)','No strong preference'].forEach(o=>{ %><option <%= q.competition_preference===o?'selected':'' %>><%= o %></option><% }) %>
        </select>
      </label>
      <label>Have you started a business before?
        <select name="prior_attempts">
          <% ['Never started one','Started but didn\'t launch','Launched, didn\'t take off','Ran one successfully','Running one right now'].forEach(o=>{ %><option <%= q.prior_attempts===o?'selected':'' %>><%= o %></option><% }) %>
        </select>
      </label>
      <label>What do you expect to be your biggest obstacle?<input name="biggest_obstacle" value="<%= q.biggest_obstacle || '' %>" placeholder="time, money, confidence, knowledge…"></label>
      <label>Who would you most enjoy serving?
        <select name="target_customer">
          <% ['Consumers (B2C)','Small businesses','Larger companies (B2B)','Other creators & founders','No preference'].forEach(o=>{ %><option <%= q.target_customer===o?'selected':'' %>><%= o %></option><% }) %>
        </select>
      </label>
      <div class="grid-2">
        <label>Comfort with selling (1-5)
          <select name="sales_comfort"><% [1,2,3,4,5].forEach(o=>{ %><option <%= q.sales_comfort===o?'selected':'' %>><%= o %></option><% }) %></select>
        </label>
        <label>Comfort with marketing (1-5)
          <select name="marketing_comfort"><% [1,2,3,4,5].forEach(o=>{ %><option <%= q.marketing_comfort===o?'selected':'' %>><%= o %></option><% }) %></select>
        </label>
      </div>
      <label>What's truly driving you to do this?<textarea name="motivation" rows="2" placeholder="freedom, family, proving something, building wealth…"><%= q.motivation || '' %></textarea></label>
    <% } %>

    <div class="cta-row">
      <% if (step > 1) { %><a class="btn btn-ghost" href="/questionnaire?step=<%= step-1 %>">Back</a><% } %>
      <button class="btn btn-primary"><%= step === steps ? 'Finish & generate my ideas →' : 'Continue →' %></button>
    </div>
  </form>
</div>
<%- include('partials/foot') %>
