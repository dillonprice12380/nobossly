<%- include('../partials/head') %>
<div class="page-head"><div><h1>🔍 SEO & site settings</h1></div></div>
<%- include('nav') %>
<div class="card form-card-wide">
  <form method="post" action="/admin/seo">
    <% settings.forEach(s => { let v = s.value; if (typeof v === 'string') v = v; else v = JSON.stringify(v); v = String(v).replace(/^"|"$/g, ''); %>
      <label><%= s.key %> <% if (s.description) { %><span class="muted small">— <%= s.description %></span><% } %>
        <input name="setting__<%= s.key %>" value="<%= v %>">
      </label>
    <% }) %>
    <button class="btn btn-primary">Save settings</button>
  </form>
</div>
<%- include('../partials/foot') %>
