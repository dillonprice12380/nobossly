<%- include('../partials/head') %>
<div class="page-head"><div><h1>💳 Pricing & Stripe</h1><p class="muted">These tiers power the public /pricing page and Stripe checkout.</p></div></div>
<%- include('nav') %>
<% if (typeof saved !== 'undefined' && saved) { %><p class="notice">Saved.</p><% } %>
<% if (!stripeConfigured) { %><p class="error">STRIPE_SECRET_KEY is not set in the server environment yet — checkout will show "payments not configured" until it's added (hPanel → your app → Environment variables).</p><% } %>
<p class="muted small">Create Products & Prices in your Stripe dashboard, then paste each Price ID (price_...) below. The lifetime tier must use a <strong>one-time</strong> price; the others must be <strong>recurring</strong> prices (1 month / 3 months / 1 year intervals).</p>
<% tiers.forEach(t => { %>
  <div class="card">
    <form method="post" action="/admin/pricing/<%= t.key %>">
      <div class="page-head"><h3><%= t.key %> <span class="chip"><%= t.mode %></span> <span class="chip"><%= t.interval_label %></span></h3>
        <label class="check"><input type="checkbox" name="is_active" <%= t.is_active ? 'checked' : '' %>> Active</label></div>
      <div class="grid-2">
        <label>Display name<input name="name" value="<%= t.name %>"></label>
        <label>Price (USD)<input name="price" type="number" step="0.01" min="0" value="<%= (t.price_cents/100).toFixed(2) %>"></label>
        <label>Tagline<input name="tagline" value="<%= t.tagline || '' %>"></label>
        <label>Stripe Price ID<input name="stripe_price_id" value="<%= t.stripe_price_id || '' %>" placeholder="price_..."></label>
      </div>
      <button class="btn btn-primary btn-sm">Save tier</button>
    </form>
  </div>
<% }) %>
<%- include('../partials/foot') %>
