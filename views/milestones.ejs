<%- include('partials/head') %>
<div class="page-head"><div><h1><svg class="icon icon-lg"><use href="#i-milestone"/></svg> Milestones</h1><p class="muted">Mark the big moments of your journey. Earn XP and badges as you go.</p></div></div>
<% const labels = { foundation: '🏛️ Foundation', product: '📦 Product', revenue: '💵 Revenue', traction: '📈 Traction', community: '🌐 Community', personal: '🎯 Personal' }; %>
<% Object.keys(cats).forEach(cat => { %>
  <div class="card">
    <h2><%= labels[cat] || cat %></h2>
    <% cats[cat].forEach(m => { const got = earned[m.id]; %>
      <div class="milestone-row">
        <div>
          <strong><%= m.emoji %> <%= m.title %></strong>
          <p class="muted small"><%= m.description %></p>
          <span class="chip">⚡ <%= m.xp_reward %> XP</span>
          <% if (m.badge_id && badgeMap[m.badge_id]) { %><span class="chip">🏅 <%= badgeMap[m.badge_id].emoji %> <%= badgeMap[m.badge_id].name %></span><% } %>
        </div>
        <% if (got) { %>
          <span class="chip chip-success">✅ <%= new Date(got.earned_at).toLocaleDateString() %></span>
        <% } else { %>
          <form method="post" action="/milestones/<%= m.id %>/achieve"><button class="btn btn-primary btn-sm">I did this!</button></form>
        <% } %>
      </div>
    <% }) %>
  </div>
<% }) %>
<%- include('partials/foot') %>
